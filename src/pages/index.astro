---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ErrorCard from '../components/ErrorCard.astro';
import { BRANDS, BRAND_LABELS, EQUIPMENT, EQUIPMENT_LABELS } from '../config';

const errors = await getCollection('errors');

const countByBrand = Object.fromEntries(
  BRANDS.map((b) => [b, errors.filter((e) => e.data.brand === b).length])
);
const countByEquipment = Object.fromEntries(
  EQUIPMENT.map((t) => [t, errors.filter((e) => e.data.equipment === t).length])
);

// A hub page, not a dump: only the most recent handful is listed inline, so the
// homepage HTML stays small no matter how many thousand articles exist.
const recent = [...errors]
  .sort((a, b) => b.data.dateModified.valueOf() - a.data.dateModified.valueOf())
  .slice(0, 12);
---

<BaseLayout
  title="HVAC Error Codes Explained & Fixed — fixme.vip"
  description="Look up your furnace, AC or heat pump error code. What it means, ranked causes, DIY checks, honest repair costs, and when to call a licensed pro."
>
  <section class="hero">
    <h1>Your furnace is flashing a code.<br />Here's what it means.</h1>
    <p>
      Brand-specific HVAC error codes decoded: ranked causes, safe DIY checks,
      honest repair costs, and when to call a licensed technician.
    </p>
    <form class="search-box" action="/fix" method="get" role="search">
      <input
        name="q"
        type="search"
        placeholder="Try “Carrier code 33” or “Goodman 3 flashes”…"
        autocomplete="off"
        aria-label="Search HVAC error codes"
      />
    </form>
  </section>

  <h2 class="section-title">By brand</h2>
  <div class="category-grid">
    {
      BRANDS.filter((b) => countByBrand[b] > 0).map((b) => (
        <a href={`/brand/${b}`}>
          {BRAND_LABELS[b]}
          <span>{countByBrand[b]} {countByBrand[b] === 1 ? 'code' : 'codes'}</span>
        </a>
      ))
    }
  </div>

  <h2 class="section-title">By equipment</h2>
  <div class="category-grid">
    {
      EQUIPMENT.filter((t) => countByEquipment[t] > 0).map((t) => (
        <a href={`/equipment/${t}`}>
          {EQUIPMENT_LABELS[t]}
          <span>{countByEquipment[t]} {countByEquipment[t] === 1 ? 'code' : 'codes'}</span>
        </a>
      ))
    }
  </div>

  <h2 class="section-title">Recently added</h2>
  {recent.map((entry) => <ErrorCard entry={entry} />)}
  <p class="applies-to">
    Looking for a specific code? <a href="/fix">Search the full library</a> or
    browse <a href="/equipment/furnace">furnaces</a>,
    <a href="/equipment/air-conditioner">air conditioners</a> and
    <a href="/equipment/heat-pump">heat pumps</a>.
  </p>
</BaseLayout>
