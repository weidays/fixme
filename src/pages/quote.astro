---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Get Free HVAC Repair Quotes from Local Pros"
  description="Tell us what your system is doing and get free, no-obligation repair quotes from licensed HVAC technicians in your area. Compare up to 3 estimates."
>
  <h1>Get free local repair quotes</h1>
  <p>
    Describe the problem and we'll match you with licensed HVAC technicians in
    your area. Free, no obligation — compare estimates before anyone visits.
  </p>

  <form id="quote-form" class="quote-form" novalidate>
    <label>
      ZIP code *
      <input name="zip" inputmode="numeric" pattern="\d{5}" maxlength="5" required placeholder="e.g. 75201" />
    </label>
    <label>
      Name
      <input name="name" maxlength="80" placeholder="First name is fine" />
    </label>
    <label>
      Email or phone *
      <input name="contact" maxlength="120" required placeholder="So a pro can reach you" />
    </label>
    <label>
      What's happening? *
      <textarea name="issue" rows="4" maxlength="1000" required placeholder="e.g. Carrier furnace flashing code 33, no heat since this morning"></textarea>
    </label>
    {/* Honeypot — bots fill it, humans never see it */}
    <input name="website" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
    <input type="hidden" name="source" id="source-field" value="direct" />
    <button type="submit" class="btn" id="quote-submit">Request free quotes</button>
  </form>

  <div id="quote-result" class="applies-to hidden" role="status"></div>

  <p class="parts-disclosure">
    By submitting, you agree to be contacted about your project by fixme.vip
    and participating local service professionals. No spam, no resale of your
    details beyond matching you with a pro.
  </p>
</BaseLayout>

<script>
  const form = document.getElementById('quote-form') as HTMLFormElement;
  const result = document.getElementById('quote-result')!;
  const submitBtn = document.getElementById('quote-submit') as HTMLButtonElement;
  const sourceField = document.getElementById('source-field') as HTMLInputElement;

  // Attribution: which code page sent this visitor here.
  const from = new URLSearchParams(location.search).get('from');
  if (from) sourceField.value = from.slice(0, 120);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(form).entries());

    if (!/^\d{5}$/.test(String(data.zip ?? ''))) {
      result.textContent = 'Please enter a valid 5-digit US ZIP code.';
      result.classList.remove('hidden');
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      const body = await res.json().catch(() => null);
      if (res.ok) {
        form.classList.add('hidden');
        result.textContent =
          "Thanks — we've got your request. We'll review it and get in touch to connect you with a licensed local HVAC technician for a free estimate.";
      } else {
        result.textContent =
          (body && body.error) || 'Something went wrong. Please try again.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Request free quotes';
      }
    } catch {
      result.textContent = 'Network error — please try again.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Request free quotes';
    }
    result.classList.remove('hidden');
  });
</script>
