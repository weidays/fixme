---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found — fixme.vip"
  description="That page doesn't exist, but your error might be in the knowledge base. Search real error messages and step-by-step fixes."
  noindex
>
  <section class="hero">
    <h1>404 — this page is broken.<br />Ironic, we know.</h1>
    <p>
      The page you're looking for doesn't exist. But the fix you're looking for
      might — look up your error code or browse by brand.
    </p>
    <p>
      <a class="btn" href="/fix">Look up your code</a>
    </p>
  </section>
</BaseLayout>
