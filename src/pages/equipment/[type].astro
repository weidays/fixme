---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErrorCard from '../../components/ErrorCard.astro';
import { EQUIPMENT, EQUIPMENT_LABELS } from '../../config';

export async function getStaticPaths() {
  const errors = await getCollection('errors');
  return EQUIPMENT.filter((type) => errors.some((e) => e.data.equipment === type)).map(
    (type) => ({ params: { type } })
  );
}

const { type } = Astro.params;
const label = EQUIPMENT_LABELS[type];

const errors = (await getCollection('errors', (e) => e.data.equipment === type)).sort(
  (a, b) => b.data.dateModified.valueOf() - a.data.dateModified.valueOf()
);
---

<BaseLayout
  title={`${label} Error Codes & Fault Lights, Explained`}
  description={`${label} error codes and blinking-light faults decoded by brand — meanings, ranked causes, honest repair costs, and when you need a licensed pro.`}
>
  <h1>{label} error codes</h1>
  <p>
    {errors.length} documented {errors.length === 1 ? 'code' : 'codes'} across
    brands, with ranked causes and repair costs.
  </p>
  {errors.map((entry) => <ErrorCard entry={entry} />)}
</BaseLayout>
