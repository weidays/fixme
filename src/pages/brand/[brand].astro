---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErrorCard from '../../components/ErrorCard.astro';
import { BRANDS, BRAND_LABELS } from '../../config';

export async function getStaticPaths() {
  const errors = await getCollection('errors');
  return BRANDS.filter((brand) => errors.some((e) => e.data.brand === brand)).map(
    (brand) => ({ params: { brand } })
  );
}

const { brand } = Astro.params;
const label = BRAND_LABELS[brand];

const errors = (await getCollection('errors', (e) => e.data.brand === brand)).sort(
  (a, b) => b.data.dateModified.valueOf() - a.data.dateModified.valueOf()
);
---

<BaseLayout
  title={`${label} Error Codes: Meanings, Causes & Fixes`}
  description={`Every ${label} HVAC error code we've decoded — what each code means, ranked causes, safe DIY checks, honest repair costs, and when to call a pro.`}
>
  <h1>{label} error codes</h1>
  <p>
    {errors.length} documented {errors.length === 1 ? 'code' : 'codes'} with
    ranked causes, repair costs, and step-by-step guidance.
  </p>
  {errors.map((entry) => <ErrorCard entry={entry} />)}
</BaseLayout>
